<Window x:Class="GeneralSystemBoard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        xmlns:local="clr-namespace:GeneralSystemBoard"
        mc:Ignorable="d"
        Title="通用框架电子看板"
        Width="1777"
        Height="1000"
        FontFamily="Microsoft YaHei"
        WindowState="Maximized"
        ResizeMode="CanResizeWithGrip" Loaded="Window_Loaded" ContentRendered="Window_ContentRendered" Icon="/shujudaping.png"
        >

    <Window.Background>
        <RadialGradientBrush Center="0.5,0" GradientOrigin="0.5,-0.8" RadiusX="0.7" RadiusY="0.7">
            <GradientStop Offset="0" Color="#A02B40" />
            <GradientStop Offset="1" Color="#08113C" />
        </RadialGradientBrush>
    </Window.Background>

    <Window.Resources>

        <Style x:Key="contentCenterStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>

    </Window.Resources>

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="80" />
            <RowDefinition />
        </Grid.RowDefinitions>

        <!--  标题  -->
        <Grid Grid.Row="0" Grid.ColumnSpan="2">
            <TextBlock
                Margin="0,13,0,0"
                HorizontalAlignment="Center"
                VerticalAlignment="top"
                FontSize="25"
                Foreground="White"
                Text="产线实时状况" />
            <TextBlock
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                FontSize="20"
                Foreground="White">
                <Run FontFamily="D:\2.IMG\Image_Major\GeneralFrame\font_zizxwqyf43\#iconfont" Text="&#xe68e;" />
                <Run x:Name="CurrentTimeTextBox" Text="2024-12-03 14:30:00" />
            </TextBlock>

        </Grid>



        <!--  标题边框  -->
        <Border
            Grid.RowSpan="2"
            Grid.ColumnSpan="2"
            Height="90"
            VerticalAlignment="Top">
            <Border.Background>
                <VisualBrush Stretch="Fill">
                    <VisualBrush.Visual>
                        <Path
                            Data="M0,0                             L0,30 400,30                             A15,10,0,0,1,414,35                             L425,51                             A10,10,0,0,0, 434,55                             L666,55                             A10 10 0 0 0 675 51                             L686,35                             A15 10 0 0 1 700 30                             L1100,30 1100,0 z"
                            Stretch="Fill"
                            StrokeThickness="1">
                            <Path.Fill>
                                <RadialGradientBrush Center="0.5,1.8" GradientOrigin="0.5,2" RadiusX="0.6" RadiusY="1.8">
                                    <GradientStop Offset="0" Color="#2BB6FE" />
                                    <GradientStop Offset="1" Color="#112BB6FE" />
                                </RadialGradientBrush>
                            </Path.Fill>
                        </Path>
                    </VisualBrush.Visual>
                </VisualBrush>
            </Border.Background>
        </Border>

        <Button
            Width="100"
            Height="50"
            Margin="0,0,10,20"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            Background="#112BB6FE"
            BorderThickness="0"
            Content="Refresh"
            Foreground="White" 
            Click="RefreshData_Click"/>

        <!--  内容  -->
        <Grid
            Grid.Row="1"
            Grid.ColumnSpan="2"
            Margin="0,20,0,30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*"/>
                <ColumnDefinition Width="1.5*" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>


            <!--  第一列  -->
            <Grid Grid.Column="0" Margin="20,15">

                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                </Grid.RowDefinitions>

                <!--  第一行  -->
                <Grid Grid.Row="0" Margin="0,0,0,0">
                    <GroupBox
                        BorderThickness="0.2"
                        FontSize="20"
                        Foreground="White"
                        Header="设备运行状态">

                        <DataGrid Name="DeviceStatusDG" IsReadOnly="True" AutoGenerateColumns="False" HeadersVisibility="Column" Background="#FF2B173D" BorderBrush="#FF2B173D" >
                            <DataGrid.Style>
                                <Style TargetType="DataGrid">
                                    <Setter Property="CanUserResizeColumns" Value="false"/>
                                    <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"></Setter>
                                    <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"></Setter>
                                    <Setter Property="HeadersVisibility" Value="Column"/>
                                </Style>
                            </DataGrid.Style>
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="HorizontalContentAlignment" Value="Center"></Setter>
                                    <Setter Property="Background" Value="#FFC3C3C3"></Setter>
                                    <Setter Property="Foreground" Value="Black"></Setter>
                                    <Setter Property="FontSize" Value="13"></Setter>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="#FF27163D" />
                                    <Setter Property="Height" Value="20"/>
                                    <Setter Property="Foreground" Value="AntiqueWhite" />
                                    <Setter Property="FontSize" Value="12"></Setter>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding ID}" Width="*" />
                                <DataGridTextColumn Header="设备名称" Binding="{Binding DeviceName}" Width="3*"/>
                                <DataGridTextColumn Header="设备地址" Binding="{Binding Address}" Width="4*"/>
                                <DataGridTextColumn Header="连接时间" Binding="{Binding ConnectedTime}" Width="4.5*"/>
                                <DataGridTextColumn Header="连接状态" Binding="{Binding Status}" Width="2*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>
                </Grid>

                <!--  第二行  -->
                <Grid Grid.Row="1" Margin="0,0,0,0">
                    <GroupBox
                        BorderThickness="0.2"
                        FontSize="20"
                        Foreground="White"
                        Header="使用者列表">

                        <DataGrid Name="UserListDG" IsReadOnly="True" AutoGenerateColumns="False" HeadersVisibility="Column" Background="#FF0D123C" BorderBrush="#FF08113C" >
                            <DataGrid.Style>
                                <Style TargetType="DataGrid">
                                    <Setter Property="CanUserResizeColumns" Value="false"/>
                                    <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"></Setter>
                                    <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"></Setter>
                                    <Setter Property="HeadersVisibility" Value="Column"/>
                                </Style>
                            </DataGrid.Style>
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="HorizontalContentAlignment" Value="Center"></Setter>
                                    <Setter Property="Background" Value="#FFC3C3C3"></Setter>
                                    <Setter Property="Foreground" Value="Black"></Setter>
                                    <Setter Property="FontSize" Value="13"></Setter>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="#FF0D123C" />
                                    <Setter Property="Height" Value="20"/>
                                    <Setter Property="Foreground" Value="AntiqueWhite" />
                                    <Setter Property="FontSize" Value="12"></Setter>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding ID}" Width="*" ElementStyle="{StaticResource contentCenterStyle}"/>
                                <DataGridTextColumn Header="设备名称" Binding="{Binding DeviceName}" Width="2.5*" ElementStyle="{StaticResource contentCenterStyle}"/>
                                <DataGridTextColumn Header="用户名称" Binding="{Binding UserName}" Width="2.5*" ElementStyle="{StaticResource contentCenterStyle}"/>
                                <DataGridTextColumn Header="连接时间" Binding="{Binding ConnectedTime}" Width="4*" ElementStyle="{StaticResource contentCenterStyle}"/>
                            </DataGrid.Columns>
                        </DataGrid>

                    </GroupBox>
                </Grid>

                <!--  第三行  -->
                <Grid Grid.Row="2" Margin="0,10,0,0">
                    <GroupBox
                        BorderThickness="0.3"
                        FontSize="22"
                        Foreground="White"
                        Header="报警信息">

                        <DataGrid Name="AlarmInfoDG" IsReadOnly="True" AutoGenerateColumns="False" HeadersVisibility="Column" Background="#FF0D123C" BorderBrush="#FF08113C" >
                            <DataGrid.Style>
                                <Style TargetType="DataGrid">
                                    <Setter Property="CanUserResizeColumns" Value="false"/>
                                    <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"></Setter>
                                    <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"></Setter>
                                    <Setter Property="HeadersVisibility" Value="Column"/>
                                </Style>
                            </DataGrid.Style>
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="HorizontalContentAlignment" Value="Center"></Setter>
                                    <Setter Property="Background" Value="#FFC3C3C3"></Setter>
                                    <Setter Property="Foreground" Value="#FF0D123C"></Setter>
                                    <Setter Property="FontSize" Value="13"></Setter>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="#FF0D123C" />
                                    <Setter Property="Height" Value="20"/>
                                    <Setter Property="Foreground" Value="AntiqueWhite" />
                                    <Setter Property="FontSize" Value="12"></Setter>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding ID}" Width="1*" ElementStyle="{StaticResource contentCenterStyle}"/>
                                <DataGridTextColumn Header="设备名称" Binding="{Binding DeviceName}" Width="2*" ElementStyle="{StaticResource contentCenterStyle}"/>
                                <DataGridTextColumn Header="报警信息" Binding="{Binding AlarmInfo}" Width="5*" ElementStyle="{StaticResource contentCenterStyle}"/>
                            </DataGrid.Columns>
                        </DataGrid>

                    </GroupBox>
                </Grid>

            </Grid>


            <!--  第二列  -->
            <!--  当日产量+完成率+x产品良品率  -->
            <Grid Grid.Column="1" Margin="0,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="150" />
                    <RowDefinition />
                    <RowDefinition />
                </Grid.RowDefinitions>

                <!--  第一行  -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.5*" />
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>

                    <!--  当日产量  -->
                    <Grid Grid.Column="0">
                        <TextBlock
                            Margin="0,0,0,70"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="22"
                            Foreground="#DD2BB6FE">
                            <Run Text="当日产量" />
                            <Run FontFamily="D:\2.IMG\Image_Major\GeneralFrame\font_zizxwqyf43\#iconfont" Text="&#xe687;" />
                        </TextBlock>
                        <TextBlock
                            x:Name="TodayProductNumText"
                            Margin="0,30,0,0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            TextBlock.FontSize="30"
                            TextBlock.Foreground="White">
                            <Run Text="13976" />
                        </TextBlock>

                    </Grid>

                    <Grid Grid.Column="1">
                        <TextBlock
                            Margin="0,0,0,70"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="22"
                            Foreground="#DD2BB6FE"
                            Text="完成率" />
                        <TextBlock
                            x:Name="TodayProductRateText"
                            Margin="0,30,0,0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="30"
                            Foreground="White"
                            Text="85%" />
                    </Grid>

                    <Grid Grid.Column="2">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            FontSize="17"
                            Foreground="#AA999999"
                            Text="A产品良品率" />
                        <lvc:Gauge
                            x:Name="AProductRateText"
                            Grid.Row="1"
                            Grid.Column="0"
                            Margin="20,0,20,0"
                            Foreground="White"
                            GaugeBackground="#BE54A3E9"
                            HighFontSize="30"
                            InnerRadius="0"
                            Uses360Mode="True"
                            Value="70"
                            From="0"
                            To="100" />
                    </Grid>

                    <Grid Grid.Column="3">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            FontSize="17"
                            Foreground="#AA999999"
                            Text="B产品良品率" />
                        <lvc:Gauge
                            x:Name="BProductRateText"
                            Grid.Row="1"
                            Grid.Column="0"
                            Margin="20,0,20,0"
                            Foreground="White"
                            GaugeBackground="#BE54A3E9"
                            HighFontSize="30"
                            InnerRadius="0"
                            Uses360Mode="True"
                            Value="90"
                            From="0"
                            To="100" />
                    </Grid>


                </Grid>

                <!--  第二行  -->
                <!--  良品率统计  -->
                <Grid Grid.Row="1" Margin="20,0,20,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="20" />
                        <RowDefinition />
                    </Grid.RowDefinitions>


                    <StackPanel
                        Grid.Row="1"
                        Margin="-10,-40,0,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Orientation="Horizontal">
                        <TextBlock
                            Margin="10,0,10,0"
                            VerticalAlignment="Center"
                            FontSize="20"
                            Foreground="White"
                            Text="生产良品率统计" />
                    </StackPanel>

                    <lvc:CartesianChart Grid.Row="1" DisableAnimations="True">
                        <lvc:CartesianChart.Series>
                            
                            <!--产品A-->
                            <lvc:LineSeries LineSmoothness="0" Stroke="#DD2BB6FE" Values="{Binding ProductRateValues1}">
                                <lvc:LineSeries.Fill>
                                    <!--  线性渐变  -->
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Offset="0" Color="#882BB6FE" />
                                        <GradientStop Offset="0.2" Color="#442BB6FE" />
                                        <GradientStop Offset="1" Color="#112BB6FE" />
                                    </LinearGradientBrush>
                                </lvc:LineSeries.Fill>
                            </lvc:LineSeries>

                            <!--产品B-->
                            <lvc:LineSeries LineSmoothness="0" Stroke="#DD2BB6FE" Values="{Binding ProductRateValues2}">
                                <lvc:LineSeries.Fill>
                                    <!--  线性渐变  -->
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Offset="0" Color="#882BB6FE" />
                                        <GradientStop Offset="0.2" Color="#442BB6FE" />
                                        <GradientStop Offset="1" Color="#112BB6FE" />
                                    </LinearGradientBrush>
                                </lvc:LineSeries.Fill>
                            </lvc:LineSeries>
                            
                        </lvc:CartesianChart.Series>
                        
                        <!--  X轴布局  -->
                        <lvc:CartesianChart.AxisX>
                            <!--  拆线图底部标签刻度，Separator表示间隔大小  -->
                            <lvc:Axis Foreground="#33FFFFFF" Labels="{Binding ProductRateLabels}">
                                <lvc:Axis.Separator>
                                    <lvc:Separator Step="1" StrokeThickness="0" />
                                </lvc:Axis.Separator>
                            </lvc:Axis>
                        </lvc:CartesianChart.AxisX>
                        <!--  Y轴布局，Step表示步长大小，MaxValue表示最大值  -->
                        <lvc:CartesianChart.AxisY>
                            <lvc:Axis Foreground="#33FFFFFF" MinValue="0" MaxValue="100">
                                <lvc:Axis.Separator>
                                    <lvc:Separator Step="25" Stroke="#10FFFFFF" />
                                </lvc:Axis.Separator>
                            </lvc:Axis>
                        </lvc:CartesianChart.AxisY>
                    </lvc:CartesianChart>
                </Grid>

                <!--  第三行  -->
                <!--  设备产量统计  -->
                <Grid Grid.Row="2" Margin="20,0,20,0">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="20" />
                        <RowDefinition />
                    </Grid.RowDefinitions>


                    <StackPanel
                        Grid.Row="1"
                        Margin="-10,-20,0,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Orientation="Horizontal">
                        <TextBlock
                            Margin="10,0,10,0"
                            VerticalAlignment="Center"
                            FontSize="20"
                            Foreground="White"
                            Text="总产量统计" />
                    </StackPanel>

                    <lvc:CartesianChart Grid.Row="1" Series="{Binding SeriesTotalNumCollection}">
                        <lvc:CartesianChart.AxisX>
                            <!--  拆线图底部标签刻度，Separator表示间隔大小  -->
                            <lvc:Axis Foreground="#33FFFFFF" Labels="{Binding TotalNumLabels}">
                                <lvc:Axis.Separator>
                                    <lvc:Separator Step="1" StrokeThickness="0" />
                                </lvc:Axis.Separator>
                            </lvc:Axis>
                        </lvc:CartesianChart.AxisX>
                        <lvc:CartesianChart.AxisY>
                            <lvc:Axis Title="产量" />
                        </lvc:CartesianChart.AxisY>
                    </lvc:CartesianChart>

                </Grid>
            </Grid>



            <!--  第三列  -->
            <!--  不良指标分页  -->
            <!--  质量控制  -->
            <Grid Grid.Column="2" Margin="20,15">
                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition />
                </Grid.RowDefinitions>

                <!--  第一行  -->
                <Grid Grid.Row="0">
                    <TextBlock
                        Margin="10,0,10,0"
                        VerticalAlignment="Top"
                        FontSize="20"
                        Foreground="White"
                        Text="当月不良统计" />
                    <Grid Margin="0,50,0,0">
                        
                        <lvc:PieChart Series="{Binding NGNumSeries}" Foreground="White" LegendLocation="Bottom" InnerRadius="0" />
                        
                    </Grid>
                    
                </Grid>


                <!--  第二行  -->
                <Grid Grid.Row="1">
                    <TextBlock
                        Margin="10,0,0,0"
                        VerticalAlignment="Top"
                        FontSize="20"
                        Foreground="White"
                        Text="当月完成情况" />

                    <Grid Margin="0,50,0,0">

                        <lvc:CartesianChart Series="{Binding NowMonthCompleteSeriesCollection}" Foreground="White" LegendLocation="Top">
                            <lvc:CartesianChart.AxisX>
                                <lvc:Axis Title="完成情况"></lvc:Axis>
                            </lvc:CartesianChart.AxisX>
                            <lvc:CartesianChart.AxisY>
                                <lvc:Axis Title="配方种类" Labels="{Binding NowMonthCompleteLabels}"></lvc:Axis>
                            </lvc:CartesianChart.AxisY>
                        </lvc:CartesianChart>
                        
                    </Grid>



                </Grid>
            </Grid>

        </Grid>

    </Grid>
</Window>
